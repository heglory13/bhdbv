PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/dbv_insurance
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
JWT_SECRET=change-this-secret
# Admin token lifetime is fixed at 24h in src/auth.js

# ── Email thông báo báo giá ──────────────────────────────────────
# Dùng Gmail SMTP. Tạo App Password tại:
# https://myaccount.google.com/apppasswords
# (Bật 2FA trước, sau đó tạo App Password cho "Mail")
MAIL_USER=your-gmail@gmail.com
MAIL_PASS=xxxx-xxxx-xxxx-xxxx
# Email nhận thông báo (mặc định dùng MAIL_USER nếu để trống)
MAIL_NOTIFY_TO=your-gmail@gmail.com
# URL admin panel để link trong email
SITE_URL=http://localhost:3000
