# ================================
# DBV Insurance - Production .env
# ================================

# Database (PostgreSQL)
DB_USER=postgres
DB_PASSWORD=YourSecurePassword123!
DATABASE_URL=postgres://postgres:YourSecurePassword123!@postgres:5432/dbv_insurance

# Backend
NODE_ENV=production
PORT=4000
JWT_SECRET=GenerateARealSecureJWTSecretHere256bits!

# Admin Credentials (CHANGE THESE!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YourSecureAdminPassword123!

# Frontend
REACT_APP_API_BASE_URL=https://your-domain.com
# Hoặc nếu dùng subdomain:
# REACT_APP_API_BASE_URL=https://api.your-domain.com
